<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>📦 Gestion de Stock - Version Définitive</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            transition: all 0.2s ease;
        }

        :root {
            --bg: #f5f7fa;
            --fg: #2d3748;
            --button-bg: #4f46e5;
            --button-fg: #ffffff;
            --entry-bg: #ffffff;
            --highlight: #e2e8f0;
            --success: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --accent: #6366f1;
            --card: #ffffff;
            --text-muted: #64748b;
        }

        body.dark {
            --bg: #1e293b;
            --fg: #f8fafc;
            --button-bg: #6366f1;
            --entry-bg: #334155;
            --highlight: #475569;
            --card: #1e293b;
            --text-muted: #94a3b8;
        }

        body {
            font-family: 'Segoe UI', 'Helvetica', Arial, sans-serif;
            background: var(--bg);
            color: var(--fg);
            margin: 0;
            padding: 20px;
            min-height: 100vh;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 2px solid var(--highlight);
        }

        .title {
            font-size: 1.8rem;
            font-weight: bold;
            color: var(--accent);
        }

        .theme-btn {
            background: var(--highlight);
            border: none;
            border-radius: 50px;
            padding: 10px 20px;
            cursor: pointer;
            font-size: 1.2rem;
            color: var(--fg);
            transition: transform 0.2s;
        }

        .theme-btn:hover {
            transform: scale(1.05);
        }

        .card {
            background: var(--card);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            border: 1px solid var(--highlight);
        }

        .card-title {
            font-size: 1.2rem;
            font-weight: bold;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--accent);
            display: inline-block;
        }

        .form-row {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            align-items: flex-end;
        }

        .form-group {
            flex: 1;
            min-width: 150px;
        }

        .form-group label {
            display: block;
            margin-bottom: 5px;
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .form-group input {
            width: 100%;
            padding: 10px 12px;
            border: 1px solid var(--highlight);
            border-radius: 8px;
            background: var(--entry-bg);
            color: var(--fg);
            font-size: 0.95rem;
            outline: none;
        }

        .form-group input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 2px rgba(99,102,241,0.2);
        }

        .btn-group {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 20px;
        }

        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.9rem;
            font-weight: 500;
            transition: all 0.2s;
        }

        .btn:hover {
            transform: translateY(-1px);
            filter: brightness(0.95);
        }

        .btn-success { background: var(--success); color: white; }
        .btn-danger { background: var(--danger); color: white; }
        .btn-warning { background: var(--warning); color: white; }
        .btn-primary { background: var(--accent); color: white; }
        .btn-secondary { background: var(--highlight); color: var(--fg); }

        .tabs {
            display: flex;
            gap: 5px;
            margin-bottom: 20px;
            border-bottom: 2px solid var(--highlight);
        }

        .tab {
            padding: 12px 24px;
            background: transparent;
            border: none;
            cursor: pointer;
            font-size: 1rem;
            font-weight: 500;
            color: var(--text-muted);
            border-radius: 8px 8px 0 0;
        }

        .tab.active {
            color: var(--accent);
            border-bottom: 2px solid var(--accent);
            background: var(--card);
        }

        .tab:hover:not(.active) {
            background: var(--highlight);
            color: var(--fg);
        }

        .tab-content {
            display: none;
            animation: fadeIn 0.3s;
        }

        .tab-content.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .list-container {
            max-height: 400px;
            overflow-y: auto;
            border: 1px solid var(--highlight);
            border-radius: 8px;
            background: var(--entry-bg);
        }

        .list-item {
            padding: 10px 15px;
            border-bottom: 1px solid var(--highlight);
            font-family: 'Consolas', monospace;
            font-size: 0.9rem;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .list-item:last-child {
            border-bottom: none;
        }

        .list-item:hover {
            background: var(--highlight);
        }

        .low-stock {
            color: var(--danger);
            font-weight: bold;
        }

        .success-item {
            color: var(--success);
        }

        .danger-item {
            color: var(--danger);
        }

        .search-bar {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        .search-bar input {
            flex: 1;
            padding: 10px 15px;
            border: 1px solid var(--highlight);
            border-radius: 8px;
            background: var(--entry-bg);
            color: var(--fg);
        }

        .toolbar {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 20px;
            padding-top: 15px;
            border-top: 1px solid var(--highlight);
        }

        .status-bar {
            background: var(--highlight);
            padding: 10px 15px;
            border-radius: 8px;
            margin-top: 20px;
            font-size: 0.85rem;
        }

        .list-container::-webkit-scrollbar {
            width: 8px;
        }

        .list-container::-webkit-scrollbar-track {
            background: var(--highlight);
            border-radius: 4px;
        }

        .list-container::-webkit-scrollbar-thumb {
            background: var(--accent);
            border-radius: 4px;
        }

        @media (max-width: 768px) {
            body { padding: 10px; }
            .form-row { flex-direction: column; }
            .btn-group { justify-content: center; }
            .tabs { flex-wrap: wrap; }
            .tab { flex: 1; text-align: center; }
        }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <div class="title">📦 GESTION DE STOCK</div>
        <button class="theme-btn" onclick="toggleTheme()">🌓 Thème</button>
    </div>

    <div class="card">
        <div class="card-title">➕ Gestion des Produits</div>
        <div class="form-row">
            <div class="form-group">
                <label>Nom du Produit</label>
                <input type="text" id="productName" placeholder="Ex: Clavier USB">
            </div>
            <div class="form-group">
                <label>Quantité</label>
                <input type="number" id="productQty" placeholder="0">
            </div>
        </div>
        <div class="btn-group">
            <button class="btn btn-success" onclick="addProduct()">📥 Ajouter</button>
            <button class="btn btn-danger" onclick="sellProduct()">📤 Vendre</button>
            <button class="btn btn-warning" onclick="deleteProduct()">🗑️ Supprimer</button>
        </div>
    </div>

    <div class="card">
        <div class="search-bar">
            <input type="text" id="searchInput" placeholder="🔍 Rechercher un produit...">
            <button class="btn btn-primary" onclick="searchProducts()">Rechercher</button>
            <button class="btn btn-secondary" onclick="clearSearch()">🧹 Effacer</button>
        </div>
    </div>

    <div class="card" style="padding: 0; overflow: hidden;">
        <div class="tabs">
            <button class="tab active" onclick="switchTab('stock')">📦 Stock Actuel</button>
            <button class="tab" onclick="switchTab('entries')">⬆️ Entrées</button>
            <button class="tab" onclick="switchTab('exits')">⬇️ Sorties</button>
        </div>

        <div id="stockTab" class="tab-content active" style="padding: 20px;">
            <div class="list-container" id="stockList"></div>
        </div>

        <div id="entriesTab" class="tab-content" style="padding: 20px;">
            <div class="list-container" id="entriesList"></div>
        </div>

        <div id="exitsTab" class="tab-content" style="padding: 20px;">
            <div class="list-container" id="exitsList"></div>
        </div>
    </div>

    <div class="toolbar">
        <button class="btn btn-primary" onclick="exportToPDF()">🖨️ Exporter PDF</button>
        <button class="btn btn-primary" onclick="printStock()">🖨️ Imprimer</button>
        <button class="btn btn-warning" onclick="clearHistory('entries')">🧹 Vider Entrées</button>
        <button class="btn btn-warning" onclick="clearHistory('exits')">🧹 Vider Sorties</button>
        <button class="btn btn-danger" onclick="resetAllData()">⚠️ Réinitialiser TOUT</button>
    </div>

    <div class="status-bar" id="statusBar">
        ✅ Prêt.
    </div>
</div>

<script>
    // Structure des données - TOUJOURS commencer vides
    let stock = {};
    let entries = [];
    let exits = [];
    let currentFilter = "";
    
    // Flag pour savoir si c'est la première initialisation
    let isFirstLoad = true;

    // Initialisation - Charge uniquement ce qui est dans localStorage
    function init() {
        loadData();
        updateAllDisplays();
        
        if (isFirstLoad) {
            if (Object.keys(stock).length === 0 && entries.length === 0 && exits.length === 0) {
                updateStatus("✅ Base de données vide. Ajoutez vos premiers produits !", "info");
            } else {
                updateStatus("✅ Données chargées avec succès.", "success");
            }
            isFirstLoad = false;
        }
    }

    // Chargement depuis localStorage - SANS DONNÉES PAR DÉFAUT
    function loadData() {
        try {
            const savedStock = localStorage.getItem("stock_app_stock");
            const savedEntries = localStorage.getItem("stock_app_entries");
            const savedExits = localStorage.getItem("stock_app_exits");

            // Ne charger que si les données existent, sinon rester vide
            if (savedStock && savedStock !== "{}") {
                stock = JSON.parse(savedStock);
            } else {
                stock = {}; // Toujours commencer vide
            }

            if (savedEntries && savedEntries !== "[]") {
                entries = JSON.parse(savedEntries);
            } else {
                entries = []; // Toujours commencer vide
            }

            if (savedExits && savedExits !== "[]") {
                exits = JSON.parse(savedExits);
            } else {
                exits = []; // Toujours commencer vide
            }
            
            console.log("Données chargées:", {stock, entries, exits});
        } catch (e) {
            console.error("Erreur chargement données:", e);
            stock = {};
            entries = [];
            exits = [];
        }
    }

    // Sauvegarde dans localStorage
    function saveData() {
        try {
            localStorage.setItem("stock_app_stock", JSON.stringify(stock));
            localStorage.setItem("stock_app_entries", JSON.stringify(entries));
            localStorage.setItem("stock_app_exits", JSON.stringify(exits));
            console.log("✅ Données sauvegardées:", {stock, entries, exits});
        } catch (e) {
            console.error("Erreur sauvegarde:", e);
            updateStatus("❌ Erreur lors de la sauvegarde!", "danger");
        }
    }

    function getCurrentDate() {
        const now = new Date();
        return now.toLocaleString('fr-FR', { 
            year: 'numeric', 
            month: '2-digit', 
            day: '2-digit',
            hour: '2-digit',
            minute: '2-digit',
            second: '2-digit'
        });
    }

    function updateStatus(message, type = "info") {
        const statusBar = document.getElementById("statusBar");
        const colors = {
            success: "#10b981",
            danger: "#ef4444",
            warning: "#f59e0b",
            info: "var(--fg)"
        };
        statusBar.style.color = colors[type] || colors.info;
        statusBar.innerHTML = message;
        
        setTimeout(() => {
            if (document.getElementById("statusBar").innerHTML === message) {
                document.getElementById("statusBar").innerHTML = "✅ Prêt.";
                document.getElementById("statusBar").style.color = "var(--fg)";
            }
        }, 3000);
    }

    // Affichages
    function updateStockDisplay() {
        const container = document.getElementById("stockList");
        if (!container) return;
        
        container.innerHTML = "";
        const sortedProducts = Object.keys(stock).sort((a,b) => a.localeCompare(b));
        
        if (sortedProducts.length === 0) {
            container.innerHTML = '<div class="list-item" style="justify-content: center; color: var(--text-muted);">📭 Aucun produit en stock. Ajoutez-en !</div>';
            return;
        }
        
        for (let name of sortedProducts) {
            if (currentFilter && !name.toLowerCase().includes(currentFilter.toLowerCase())) {
                continue;
            }
            const qty = stock[name];
            const item = document.createElement("div");
            item.className = "list-item";
            if (qty < 5) item.classList.add("low-stock");
            item.innerHTML = `
                <span>${escapeHtml(name)}</span>
                <span style="font-weight: bold;">Stock: ${qty}</span>
            `;
            item.onclick = () => fillForm(name);
            container.appendChild(item);
        }
    }

    function updateEntriesDisplay() {
        const container = document.getElementById("entriesList");
        if (!container) return;
        
        container.innerHTML = "";
        
        if (entries.length === 0) {
            container.innerHTML = '<div class="list-item" style="justify-content: center; color: var(--text-muted);">📭 Aucune entrée enregistrée.</div>';
            return;
        }
        
        const sortedEntries = [...entries].sort((a,b) => new Date(b.date) - new Date(a.date));
        
        for (let entry of sortedEntries) {
            const item = document.createElement("div");
            item.className = "list-item success-item";
            item.innerHTML = `
                <span>${entry.date}</span>
                <span>${escapeHtml(entry.name)}</span>
                <span style="font-weight: bold;">+${entry.quantity}</span>
            `;
            container.appendChild(item);
        }
    }

    function updateExitsDisplay() {
        const container = document.getElementById("exitsList");
        if (!container) return;
        
        container.innerHTML = "";
        
        if (exits.length === 0) {
            container.innerHTML = '<div class="list-item" style="justify-content: center; color: var(--text-muted);">📭 Aucune sortie enregistrée.</div>';
            return;
        }
        
        const sortedExits = [...exits].sort((a,b) => new Date(b.date) - new Date(a.date));
        
        for (let exit of sortedExits) {
            const item = document.createElement("div");
            item.className = "list-item danger-item";
            item.innerHTML = `
                <span>${exit.date}</span>
                <span>${escapeHtml(exit.name)}</span>
                <span style="font-weight: bold;">-${exit.quantity}</span>
            `;
            container.appendChild(item);
        }
    }

    function updateAllDisplays() {
        updateStockDisplay();
        updateEntriesDisplay();
        updateExitsDisplay();
    }

    function fillForm(name) {
        document.getElementById("productName").value = name;
        document.getElementById("productQty").focus();
    }

    // Actions principales
    function addProduct() {
        const name = document.getElementById("productName").value.trim();
        const qtyInput = document.getElementById("productQty").value.trim();
        
        if (!name) {
            updateStatus("⚠️ Veuillez saisir un nom de produit.", "warning");
            return;
        }
        
        const qty = parseInt(qtyInput);
        if (isNaN(qty) || qty <= 0) {
            updateStatus("⚠️ Veuillez saisir une quantité valide (>0).", "warning");
            return;
        }
        
        if (stock[name]) {
            stock[name] += qty;
        } else {
            stock[name] = qty;
        }
        
        entries.unshift({ date: getCurrentDate(), name: name, quantity: qty });
        saveData();
        updateAllDisplays();
        document.getElementById("productName").value = "";
        document.getElementById("productQty").value = "";
        updateStatus(`✅ Produit "${name}" ajouté avec succès (+${qty}).`, "success");
    }
    
    function sellProduct() {
        const name = document.getElementById("productName").value.trim();
        const qtyInput = document.getElementById("productQty").value.trim();
        
        if (!name) {
            updateStatus("⚠️ Veuillez saisir un nom de produit.", "warning");
            return;
        }
        
        const qty = parseInt(qtyInput);
        if (isNaN(qty) || qty <= 0) {
            updateStatus("⚠️ Veuillez saisir une quantité valide (>0).", "warning");
            return;
        }
        
        if (!stock[name]) {
            updateStatus(`❌ Produit "${name}" non trouvé.`, "danger");
            return;
        }
        
        if (stock[name] < qty) {
            updateStatus(`❌ Stock insuffisant pour "${name}". Stock actuel: ${stock[name]}`, "danger");
            return;
        }
        
        stock[name] -= qty;
        exits.unshift({ date: getCurrentDate(), name: name, quantity: qty });
        
        if (stock[name] === 0) {
            delete stock[name];
        }
        
        saveData();
        updateAllDisplays();
        document.getElementById("productName").value = "";
        document.getElementById("productQty").value = "";
        updateStatus(`✅ Vente de "${name}" enregistrée (-${qty}).`, "success");
    }
    
    function deleteProduct() {
        const name = document.getElementById("productName").value.trim();
        
        if (!name) {
            updateStatus("⚠️ Veuillez saisir un nom de produit à supprimer.", "warning");
            return;
        }
        
        if (!stock[name]) {
            updateStatus(`❌ Produit "${name}" non trouvé.`, "danger");
            return;
        }
        
        if (confirm(`⚠️ Voulez-vous vraiment supprimer "${name}" définitivement ?`)) {
            delete stock[name];
            saveData();
            updateAllDisplays();
            document.getElementById("productName").value = "";
            document.getElementById("productQty").value = "";
            updateStatus(`✅ Produit "${name}" supprimé définitivement.`, "success");
        }
    }
    
    function searchProducts() {
        currentFilter = document.getElementById("searchInput").value.trim();
        updateStockDisplay();
        updateStatus(`🔍 Recherche: "${currentFilter || 'tous les produits'}"`, "info");
    }
    
    function clearSearch() {
        document.getElementById("searchInput").value = "";
        currentFilter = "";
        updateStockDisplay();
        updateStatus("Recherche effacée.", "info");
    }
    
    function clearHistory(type) {
        if (type === 'entries') {
            if (confirm("⚠️⚠️⚠️ Voulez-vous vraiment SUPPRIMER DÉFINITIVEMENT tout l'historique des entrées ?\n\nCette action est IRRÉVERSIBLE !")) {
                entries = [];
                saveData();
                updateEntriesDisplay();
                updateStatus("✅ Historique des entrées vidé définitivement.", "success");
            }
        } else if (type === 'exits') {
            if (confirm("⚠️⚠️⚠️ Voulez-vous vraiment SUPPRIMER DÉFINITIVEMENT tout l'historique des sorties ?\n\nCette action est IRRÉVERSIBLE !")) {
                exits = [];
                saveData();
                updateExitsDisplay();
                updateStatus("✅ Historique des sorties vidé définitivement.", "success");
            }
        }
    }
    
    function resetAllData() {
        if (confirm("🔴🔴🔴 ATTENTION ! Cette action va SUPPRIMER DÉFINITIVEMENT TOUTES les données :\n\n• Tous les produits en stock\n• Tout l'historique des entrées\n• Tout l'historique des sorties\n\nCette action est IRRÉVERSIBLE !\n\nVoulez-vous vraiment continuer ?")) {
            
            // Vider complètement toutes les données
            stock = {};
            entries = [];
            exits = [];
            
            // Sauvegarder le vide
            saveData();
            
            // Mettre à jour l'affichage
            updateAllDisplays();
            
            // Vider les champs
            document.getElementById("productName").value = "";
            document.getElementById("productQty").value = "";
            document.getElementById("searchInput").value = "";
            currentFilter = "";
            
            updateStatus("🔴 TOUTES les données ont été définitivement supprimées. L'application est maintenant vide.", "danger");
            
            // Forcer un rechargement visuel
            setTimeout(() => {
                updateAllDisplays();
            }, 100);
        }
    }
    
    // Export PDF et impression
    function exportToPDF() {
        const printWindow = window.open('', '_blank');
        let htmlContent = `
        <!DOCTYPE html>
        <html>
        <head>
            <title>Inventaire des Stocks</title>
            <meta charset="UTF-8">
            <style>
                body { font-family: Arial, sans-serif; margin: 40px; }
                h1 { color: #4f46e5; border-bottom: 2px solid #4f46e5; }
                h2 { color: #6366f1; margin-top: 30px; }
                table { width: 100%; border-collapse: collapse; margin-top: 20px; }
                th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
                th { background-color: #4f46e5; color: white; }
                .footer { margin-top: 30px; font-size: 12px; color: #666; text-align: center; }
                .low { color: #ef4444; font-weight: bold; }
                .success { color: #10b981; }
                .danger { color: #ef4444; }
                .empty { text-align: center; color: #999; font-style: italic; }
            </style>
        </head>
        <body>
            <h1>📦 Rapport complet de gestion de stock</h1>
            <p>Généré le ${getCurrentDate()}</p>
            
            <h2>Stock actuel</h2>`;
        
        if (Object.keys(stock).length === 0) {
            htmlContent += `<p class="empty">Aucun produit en stock.</p>`;
        } else {
            htmlContent += `<table><thead><tr><th>Produit</th><th>Stock</th></tr></thead><tbody>`;
            const sortedProducts = Object.keys(stock).sort();
            for (let name of sortedProducts) {
                const qty = stock[name];
                const lowClass = qty < 5 ? 'class="low"' : '';
                htmlContent += `<tr ${lowClass}><td>${escapeHtml(name)}</td><td>${qty}</td></tr>`;
            }
            htmlContent += `</tbody></table>`;
        }
        
        htmlContent += `<h2>Historique des entrées</h2>`;
        if (entries.length === 0) {
            htmlContent += `<p class="empty">Aucune entrée enregistrée.</p>`;
        } else {
            htmlContent += `<table><thead><tr><th>Date</th><th>Produit</th><th>Quantité</th></tr></thead><tbody>`;
            for (let entry of entries.slice(-50).reverse()) {
                htmlContent += `<tr class="success"><td>${entry.date}</td><td>${escapeHtml(entry.name)}</td><td>+${entry.quantity}</td></tr>`;
            }
            htmlContent += `</tbody></table>`;
        }
        
        htmlContent += `<h2>Historique des sorties</h2>`;
        if (exits.length === 0) {
            htmlContent += `<p class="empty">Aucune sortie enregistrée.</p>`;
        } else {
            htmlContent += `<table><thead><tr><th>Date</th><th>Produit</th><th>Quantité</th></tr></thead><tbody>`;
            for (let exit of exits.slice(-50).reverse()) {
                htmlContent += `<tr class="danger"><td>${exit.date}</td><td>${escapeHtml(exit.name)}</td><td>-${exit.quantity}</td></tr>`;
            }
            htmlContent += `</tbody></table>`;
        }
        
        htmlContent += `
            <div class="footer">
                Rapport généré automatiquement par l'application de Gestion de Stock
            </div>
        </body>
        </html>`;
        
        printWindow.document.write(htmlContent);
        printWindow.document.close();
        printWindow.print();
        updateStatus("✅ Export PDF/Impression lancé.", "success");
    }
    
    function printStock() {
        exportToPDF();
    }
    
    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }
    
    // Interface onglets
    function switchTab(tabName) {
        document.querySelectorAll('.tab').forEach(tab => tab.classList.remove('active'));
        document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
        
        if (tabName === 'stock') {
            document.querySelectorAll('.tab')[0].classList.add('active');
            document.getElementById('stockTab').classList.add('active');
            updateStockDisplay();
        } else if (tabName === 'entries') {
            document.querySelectorAll('.tab')[1].classList.add('active');
            document.getElementById('entriesTab').classList.add('active');
            updateEntriesDisplay();
        } else if (tabName === 'exits') {
            document.querySelectorAll('.tab')[2].classList.add('active');
            document.getElementById('exitsTab').classList.add('active');
            updateExitsDisplay();
        }
    }
    
    // Thème
    function toggleTheme() {
        document.body.classList.toggle('dark');
        const isDark = document.body.classList.contains('dark');
        localStorage.setItem("stock_app_theme", isDark ? "dark" : "light");
        updateStatus(`Thème ${isDark ? "sombre" : "clair"} activé.`, "info");
    }
    
    function loadTheme() {
        const savedTheme = localStorage.getItem("stock_app_theme");
        if (savedTheme === "dark") {
            document.body.classList.add("dark");
        }
    }
    
    // Événements
    document.addEventListener('DOMContentLoaded', () => {
        loadTheme();
        init();
        
        let searchTimeout;
        const searchInput = document.getElementById("searchInput");
        searchInput.addEventListener('input', () => {
            clearTimeout(searchTimeout);
            searchTimeout = setTimeout(() => {
                searchProducts();
            }, 300);
        });
        
        document.getElementById("productQty").addEventListener('keypress', (e) => {
            if (e.key === 'Enter') addProduct();
        });
        document.getElementById("productName").addEventListener('keypress', (e) => {
            if (e.key === 'Enter') document.getElementById("productQty").focus();
        });
    });
</script>
</body>
</html>
